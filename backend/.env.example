# Optional server-side fallbacks. The frontend forwards per-user credentials
# via request headers, so these are only used when a header is absent.

ANGEL_CLIENT_ID=
ANGEL_API_KEY=
ANGEL_PIN=
ANGEL_TOTP_SECRET=
GROQ_API_KEY=

# Comma-separated list of allowed CORS origins for the dev frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Groq model used by sentiment tagging and the agent pipeline.
GROQ_MODEL=llama3-70b-8192
